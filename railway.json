{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd DFP-NEO-V2-fresh && npm ci && npm run build"
  },
  "deploy": {
    "startCommand": "cd DFP-NEO-V2-fresh && node server.js",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE"
  }
}