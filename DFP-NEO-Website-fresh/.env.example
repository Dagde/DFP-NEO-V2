# Shared Database Configuration
# Uses the SAME database as the original DFP-NEO app
DATABASE_URL="postgresql://user:password@host:5432/database"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-generate-with-openssl-rand-base64-32"

# App URLs - Where to redirect after selecting an app
NEXT_PUBLIC_FLIGHT_SCHOOL_URL="/flight-school"
NEXT_PUBLIC_RECONNAISSANCE_URL="https://your-v2-app-url.railway.app"